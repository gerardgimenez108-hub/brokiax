rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny all by default to prevent unauthorized access and high billing costs
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection
    match /users/{userId} {
      // Users can only read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Subcollections isolated to the owner
      match /apiKeys/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /strategies/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /traders/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /portfolio/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
