rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection
    match /users/{userId} {
      // Users can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Users can create their own profile
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['email', 'displayName', 'plan'])
        && request.resource.data.plan in ['starter', 'pro', 'elite', 'enterprise'];
      
      // Users can update their own profile BUT cannot modify plan/subscription (server-side only)
      allow update: if request.auth != null && request.auth.uid == userId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'subscriptionStatus', 'stripeCustomerId']));
      
      // API Keys subcollection
      match /apiKeys/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Exchange Keys subcollection
      match /exchangeKeys/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Strategies subcollection
      match /strategies/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Traders subcollection (and nested trades/logs)
      match /traders/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Portfolio / Metrics subcollection
      match /portfolio/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /metrics/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
